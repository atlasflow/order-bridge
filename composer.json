{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "atlasflow/order-bridge",
    "description": "Serialisation, validation and transport for the Atlas Core Order Bridge API.",
    "type": "library",
    "license": "proprietary",
    "keywords": [
        "atlasflow",
        "atlascore",
        "erp",
        "order",
        "bridge",
        "php"
    ],
    "require": {
        "php": "^8.4",
        "ext-bcmath": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "nyholm/psr7": "^1.8",
        "pestphp/pest": "^3.0 || ^4.0",
        "phpstan/phpstan": "^2.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Atlasflow\\OrderBridge\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Atlasflow\\OrderBridge\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": [
            "@lint:check",
            "@php vendor/bin/pest"
        ],
        "lint": [
            "@php vendor/bin/pint --parallel"
        ],
        "lint:check": [
            "@php vendor/bin/pint --parallel --test"
        ],
        "analyse": [
            "@php vendor/bin/phpstan analyse"
        ],
        "refactor": [
            "@php vendor/bin/rector"
        ],
        "refactor:dry": [
            "@php vendor/bin/rector --dry-run"
        ],
        "ci:check": [
            "Composer\\Config::disableProcessTimeout",
            "@lint:check",
            "@analyse",
            "@php vendor/bin/pest --ci"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
